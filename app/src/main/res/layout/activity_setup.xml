<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/setup_background"
    android:padding="32dp">

    <!-- Icon -->
    <ImageView
        android:id="@+id/appIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_app_logo"
        android:contentDescription="@string/app_name"
        app:layout_constraintBottom_toTopOf="@id/appTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.35" />

    <!-- App Name -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/app_name"
        android:textColor="@color/setup_text_primary"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appIcon" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/setup_subtitle"
        android:textColor="@color/setup_text_secondary"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appTitle" />

    <!-- URL Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/urlInputLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:hint="@string/hint_server_url"
        app:startIconDrawable="@drawable/ic_server"
        app:errorEnabled="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintWidth_max="400dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:imeOptions="actionGo"
            android:maxLines="1"
            android:textColor="@color/setup_text_primary" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Helper text -->
    <TextView
        android:id="@+id/helperText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="16dp"
        android:text="@string/setup_helper"
        android:textColor="@color/setup_text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/urlInputLayout"
        app:layout_constraintStart_toStartOf="@id/urlInputLayout"
        app:layout_constraintTop_toBottomOf="@id/urlInputLayout" />

    <!-- Connect Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/connectButton"
        style="@style/Widget.Material3.Button"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="@string/button_connect"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="@id/urlInputLayout"
        app:layout_constraintStart_toStartOf="@id/urlInputLayout"
        app:layout_constraintTop_toBottomOf="@id/helperText" />

</androidx.constraintlayout.widget.ConstraintLayout>
