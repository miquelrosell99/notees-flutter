<?xml version="1.0" encoding="utf-8"?>
<!--
  Static app shortcuts — appear when the user long-presses the launcher icon.
  Dynamic shortcuts (pinned to home screen etc.) are handled at runtime via
  ShortcutManagerCompat if needed.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="quick_note"
        android:enabled="true"
        android:icon="@drawable/ic_quick_note"
        android:shortcutShortLabel="@string/shortcut_quick_note_short"
        android:shortcutLongLabel="@string/shortcut_quick_note_long">

        <intent
            android:action="com.notees.app.ACTION_QUICK_NOTE"
            android:targetPackage="com.notees.app"
            android:targetClass="com.notees.app.MainActivity" />

        <categories android:name="android.shortcut.conversation" />
    </shortcut>

</shortcuts>
