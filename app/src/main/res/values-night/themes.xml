<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark theme -->
    <style name="Theme.Notees" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorError">@color/error_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.Notees.Setup" parent="Theme.Notees">
        <item name="android:statusBarColor">@color/background_dark</item>
    </style>

    <!-- Splash screen (dark variant) -->
    <style name="Theme.Notees.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_app_logo</item>
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="postSplashScreenTheme">@style/Theme.Notees</item>
    </style>

</resources>
